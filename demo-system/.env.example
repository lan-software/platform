# Lan-Software public demo — env template
# Copy to .env and edit. scripts/up.sh will auto-generate any empty *_APP_KEY
# and POSTGRES_PASSWORD values on first run.

# ----- DNS / hostnames -----
# The primary demo domain (shown in mail from-addresses, banner text, etc).
DEMO_DOMAIN=demo.lan-software.de

# Each Lan* app is served on its own hostname. Cloudflare/DNS must route all
# six of these to this host's public IP. Caddy obtains LE certs automatically.
DEMO_LANCORE_HOST=demo.lan-software.de
DEMO_LANBRACKETS_HOST=brackets.demo.lan-software.de
DEMO_LANENTRANCE_HOST=entrance.demo.lan-software.de
DEMO_LANHELP_HOST=help.demo.lan-software.de
DEMO_LANSHOUT_HOST=shout.demo.lan-software.de
DEMO_MAILPIT_HOST=mail.demo.lan-software.de

# Email used for Let's Encrypt registration.
CADDY_LE_EMAIL=ops@lan-software.de

# ----- Secrets (rotated on every reset.sh run) -----
# Leave empty — up.sh/reset.sh will populate them.
POSTGRES_PASSWORD=

LANCORE_APP_KEY=
LANBRACKETS_APP_KEY=
LANENTRANCE_APP_KEY=
LANHELP_APP_KEY=
LANSHOUT_APP_KEY=

# ----- Idle detection -----
# Seconds of inactivity after which reset.sh skips. Default: 3600 (one hour).
RESET_INTERVAL_SECONDS=3600
