# Profile selects config/profiles/<PROFILE>.json
PROFILE=local

# Override baseUrl from the profile if set
BASE_URL=http://host.docker.internal

# VU/duration overrides (optional; scenarios have sane defaults)
TARGET_VUS=500
DURATION=2m

# Bearer token for integration check-in API scenarios (required for checkin-api.js)
# INTEGRATION_TOKEN=

# Host port bindings
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
